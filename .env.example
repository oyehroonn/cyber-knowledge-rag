# HackerOne (optional: for authenticated hacktivity scraping)
# Get more reports by logging in. Leave empty to scrape without login.
HACKERONE_EMAIL=
HACKERONE_PASSWORD=

# LLM: Open Router (DeepSeek) or direct DeepSeek API
# Open Router: DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1, DEEPSEEK_API_KEY=<openrouter-key>
# Direct: DEEPSEEK_BASE_URL=https://api.deepseek.com, DEEPSEEK_MODEL=deepseek-reasoner
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_MODEL=deepseek/deepseek-chat
